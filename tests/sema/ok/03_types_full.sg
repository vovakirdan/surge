// Basic type grammar
type I = int;             // если включил typedef
fn id(x:int) -> int { return x; }

let a:int = 1;
let b:float = 2.0;
let c:bool = true;
let d:string = "s";

let xs:int[] = [1,2,3];
let r:int = xs[0];

let rx:&int = &a;            // синтаксис ссылок в значениях будет позже, сейчас только типы в сигнатурах
fn fch(ch:channel<int>) -> int { return 0; }

fn g(p:&int, q:own int) -> int { return *p + q; } // семантика разыменования позже

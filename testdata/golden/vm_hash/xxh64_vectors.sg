import stdlib/hash as hash;

fn bytes_range(start: int, end: int) -> byte[] {
    let mut out: byte[] = [];
    let mut i: int = start;
    while i < end {
        out.push(i to byte);
        i = i + 1;
    }
    return out;
}

fn check(got: hash.Hash64, expected: uint64) -> bool {
    return got.as_u64() == expected;
}

@entrypoint
fn main() -> int {
    let empty: byte[] = [];
    let text_a: string = "a";
    let text_hello: string = "hello";
    let text_he: string = "he";
    let text_llo: string = "llo";
    if !check(hash.xxh64_bytes(&empty, 0:uint64), 0xEF46DB3751D8E999:uint64) {
        return 1;
    }
    if !check(hash.xxh64_string(&text_a, 0:uint64), 0xD24EC4F1A98C6E5B:uint64) {
        return 2;
    }
    if !check(hash.xxh64_string(&text_hello, 0:uint64), 0x26C7827D889F6DA3:uint64) {
        return 3;
    }
    if !check(hash.xxh64_string(&text_hello, 1:uint64), 0x23DD71CB04D0A1B2:uint64) {
        return 4;
    }

    let bytes32: byte[] = bytes_range(0, 32);
    if !check(hash.xxh64_bytes(&bytes32, 0:uint64), 0xCBF59C5116FF32B4:uint64) {
        return 5;
    }

    let bytes64: byte[] = bytes_range(0, 64);
    if !check(hash.xxh64_bytes(&bytes64, 7:uint64), 0x3C65D1809A38A9BF:uint64) {
        return 6;
    }

    let first: byte[] = bytes_range(0, 17);
    let second: byte[] = bytes_range(17, 64);
    let mut streamed: hash.Xxh64 = hash.Xxh64::new(7:uint64);
    streamed.update_bytes(&first);
    streamed.update_bytes(&second);
    let streamed_digest: hash.Hash64 = streamed.finish();
    let one_shot_digest: hash.Hash64 = hash.xxh64_bytes(&bytes64, 7:uint64);
    if streamed_digest.as_u64() != one_shot_digest.as_u64() {
        return 7;
    }

    let mut streamed_text: hash.Xxh64 = hash.Xxh64::new(0:uint64);
    streamed_text.update_string_bytes(&text_he);
    streamed_text.update_string_bytes(&text_llo);
    let streamed_text_digest: hash.Hash64 = streamed_text.finish();
    let one_shot_text_digest: hash.Hash64 = hash.xxh64_string(&text_hello, 0:uint64);
    if streamed_text_digest.as_u64() != one_shot_text_digest.as_u64() {
        return 8;
    }

    let mut byte_streamed: hash.Xxh64 = hash.Xxh64::new(0:uint64);
    byte_streamed.update_byte(104:byte);
    byte_streamed.update_byte(101:byte);
    byte_streamed.update_byte(108:byte);
    byte_streamed.update_byte(108:byte);
    byte_streamed.update_byte(111:byte);
    let byte_streamed_digest: hash.Hash64 = byte_streamed.finish();
    if byte_streamed_digest.as_u64() != one_shot_text_digest.as_u64() {
        return 9;
    }

    return 0;
}

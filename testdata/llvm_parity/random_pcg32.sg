import stdlib/random as random;

@entrypoint
fn main() -> int {
    compare random.bytes(3:uint) {
        Success(xs) => {
            if xs.__len() != 3:uint {
                return 1;
            }
        }
        err => {
            return err.code to int;
        }
    };

    let mut rng: random.Pcg32 = random.pcg32_stream(42:uint64, 54:uint64);
    compare rng.next_u32() {
        Success(v0) => {
            if v0 != 2707161783:uint32 {
                return 2;
            }
        }
        err => {
            return err.code to int;
        }
    };
    compare rng.next_u32() {
        Success(v1) => {
            if v1 != 2068313097:uint32 {
                return 3;
            }
        }
        err => {
            return err.code to int;
        }
    };

    let mut rng_fill: random.Pcg32 = random.pcg32_stream(42:uint64, 54:uint64);
    let mut out: byte[] = Array::<byte>.with_len(8:uint);
    compare rng_fill.fill(&mut out) {
        Success(_) => {}
        err => {
            return err.code to int;
        }
    };
    if out[0] != 183:uint8 || out[1] != 2:uint8 || out[2] != 92:uint8 || out[3] != 161:uint8 {
        return 4;
    }
    if out[4] != 9:uint8 || out[5] != 244:uint8 || out[6] != 71:uint8 || out[7] != 123:uint8 {
        return 5;
    }

    let mut rng64: random.Pcg32 = random.pcg32_stream(42:uint64, 54:uint64);
    compare rng64.next_u64() {
        Success(v64) => {
            if v64 != 8883337112210637495:uint64 {
                return 6;
            }
        }
        err => {
            return err.code to int;
        }
    };

    return 0;
}

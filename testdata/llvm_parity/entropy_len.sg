import stdlib/entropy as entropy;

@entrypoint
fn main() -> int {
    let mut out: byte[] = Array::<byte>.with_len(3:uint);

    compare entropy.fill(&mut out) {
        Success(_) => {}
        err => {
            return err.code to int;
        }
    };

    compare entropy.bytes(5:uint) {
        Success(bytes) => {
            if out.__len() == 3:uint && bytes.__len() == 5:uint {
                return 0;
            }
            return 99;
        }
        err => {
            return err.code to int;
        }
    };
}

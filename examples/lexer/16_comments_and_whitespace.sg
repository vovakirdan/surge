// Тест комментариев и пробелов
fn test_comments() -> int {
    // Это однострочный комментарий
    let x:int = 42; /* Это многострочный комментарий */
    
    /* 
     * Многострочный комментарий
     * с несколькими строками
     */
    
    let y:int = 10; // Комментарий в конце строки
    let z:int = 5; /* Комментарий в конце строки */
    
    return x + y + z;
}
